    "start": "node dist/server.js",
    "build": "npm run build-ts && npm run lint",
    "build-ts": "npx tsc && tsc-alias",
    "watch-ts": "npx tsc -w",
    "lint": "npx eslint src/**/*.ts test/**/*.ts",
    "test": "cross-env DOTENV_CONFIG_PATH=test.env jest --detectOpenHandles",
    "test:ci": "npm run test",
    "test:compose": "docker compose -f docker/docker-compose.ci.yml up --abort-on-container-exit --build --force-recreate --remove-orphans",
    "test:win": "cross-env DOTENV_CONFIG_PATH=test.env jest --detectOpenHandles",
    "debug:sequelize": "cross-env DEBUG=sequelize:* node dist/server.js"
  },
