{
  "realm": "aoe",
  "enabled": true,
  "sslRequired": "none",
  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": false,
      "defaultAction": false
    }
  ],
  "clients": [
    {
      "clientId": "aoe-client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "fullScopeAllowed": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "aoe-secret",
      "redirectUris": [
        "http://localhost:33344/api/secure/redirect",
        "https://demo.aoe.fi/api/secure/redirect"
      ],
      "webOrigins": ["*"],
      "protocolMappers": [
        {
          "name": "uid",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "uid",
            "claim.name": "uid",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        }
      ],
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email", "basic"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"],
      "attributes": {
        "post.logout.redirect.uris": ""
      }
    }
  ],
  "users": [
    {
      "username": "aoeuser",
      "enabled": true,
      "firstName": "AOE_first",
      "lastName": "AOE_last",
      "email": "aoeuser@aoe.fi",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["offline_access"],
      "attributes": {
        "uid": ["c37ccf17-c8b8-4d5f-b2be-a751f8a4f46e"]
      }
    },
    {
      "username": "tuomas.jukola",
      "enabled": true,
      "firstName": "Tuomas",
      "lastName": "Jukola",
      "email": "tuomas.jukola@aoe.fi",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password123",
          "temporary": false
        }
      ],
      "realmRoles": ["offline_access"],
      "attributes": {
        "uid": ["d48ddf28-d9c9-5e6g-c3cf-b862g9b5g57f"]
      }
    }
  ]
}
